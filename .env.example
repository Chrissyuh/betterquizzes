# BetterQuizzes V1 environment examples
PORT=8787
HOST=127.0.0.1

# Set this to your public HTTPS origin when using a tunnel or deployed host.
# Example: https://energize-service-spruce.ngrok-free.dev
PUBLIC_BASE_URL=

# Optional alias. PUBLIC_ORIGIN wins if both are set.
PUBLIC_ORIGIN=

# Submission-ready widget origin. Defaults in code to https://quizzes.trybettertools.com.
WIDGET_DOMAIN=

# Optional CORS restriction. Default is * for local prototyping.
CORS_ORIGIN=*

# Optional protocol override.
MCP_PROTOCOL_VERSION=2025-06-18
